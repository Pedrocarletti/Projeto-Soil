# Public API domain and allowed frontend origin
API_DOMAIN=api.seu-dominio.com
FRONTEND_URL=https://seu-projeto.vercel.app

# E-mail used by Traefik for Let's Encrypt
ACME_EMAIL=voce@seudominio.com

# Internal database settings
POSTGRES_DB=soil
POSTGRES_USER=soil
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# API auth
JWT_SECRET=troque-por-um-segredo-longo-e-unico
JWT_EXPIRES_IN=12h

# Seeded admin created on first boot and updated on subsequent boots
SEED_ADMIN_NAME=Administrador Soil
SEED_ADMIN_EMAIL=admin@seudominio.com
SEED_ADMIN_PASSWORD=troque-por-uma-senha-forte

# Optional MQTT overrides. Leave as-is to use the internal Mosquitto.
REDIS_URL=redis://redis:6379
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PATTERN=pivots/+/telemetry
MQTT_COMMAND_TOPIC=pivots/{code}/commands
MQTT_LOCAL_ECHO_COMMANDS=true
